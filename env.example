# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (for server-side admin operations — keep private!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — email sending https://resend.com
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=noreply@renewmytie.com

# Cron job secret — set to a random string, used to verify Vercel Cron calls
CRON_SECRET=your-random-secret-here

# Site URL — used for redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
